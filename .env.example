# Database
DATABASE_URL=postgresql://ohmydok:ohmydok_secret@localhost:5432/ohmydok

# App URLs
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT Secret (change in production)
JWT_SECRET=your-secret-key-here

# Port (default 3000, Docker uses 8080)
PORT=3000

# Super Admin (auto-created on server start if not exists)
SUPER_ADMIN_EMAIL=admin@ohmydok.com
SUPER_ADMIN_PASSWORD=Admin123!
SUPER_ADMIN_FIRST_NAME=Admin
SUPER_ADMIN_LAST_NAME=OMD

# Groq API Key (for document verification via VLM/LLM)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Commission Rates (override defaults)
# PLATFORM_COMMISSION_RATE=5
# REGIONAL_COMMISSION_RATE=10
